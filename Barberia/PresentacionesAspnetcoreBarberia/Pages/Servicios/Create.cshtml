@page
@model PresentacionesAspnetcoreBarberia.Pages.Servicios.CreateModel
@{
    ViewData["Title"] = "Nueva Servicio";
}

<div class="container mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
                <div class="card-header" style="background-color: #D4AF37; color: #121212;">
                    <h3 class="mb-0 fw-bold">📅 Registrar Nueva Servicio</h3>
                </div>
                <div class="card-body">
                    <form method="post">

                        <div class="mb-3">
                            <label asp-for="Servicio.Nombre" class="form-label" style="color: #D4AF37; font-weight: bold;">Nombre de la Servicio</label>
                            <input asp-for="Servicio.Nombre" type="text" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Servicio.Nombre" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Servicio.Costo" class="form-label" style="color: #D4AF37; font-weight: bold;">Costo de la Servicio</label>
                            <input asp-for="Servicio.Costo" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Servicio.Costo" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Servicio.Tiempo" class="form-label" style="color: #D4AF37; font-weight: bold;">Tiempo del Servicio</label>
                            <input asp-for="Servicio.Tiempo" type="time" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Servicio.Tiempo" class="text-danger"></span>
                        </div>

                        

                        <div class="mb-3">
                            <label asp-for="Servicio.Nota" class="form-label" style="color: #D4AF37; font-weight: bold;">Nota</label>
                            <input asp-for="Servicio.Nota" type="text" class="form-control text-white" placeholder="Ej: 1" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Servicio.Nota" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn fw-bold" style="background-color: #D4AF37; color: #121212;">
                                💾 Guardar Servicio
                            </button>
                            <a asp-page="Index" class="btn btn-outline-light">⬅️ Cancelar y Volver</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}