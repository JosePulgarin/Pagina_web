@page "{id:int}"
@model PresentacionesAspnetcoreBarberia.Pages.Membresias.EditModel
@{
    ViewData["Title"] = "Editar Membresia";
}

<div class="container mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
                <div class="card-header" style="background-color: #D4AF37; color: #121212;">
                    <h3 class="mb-0 fw-bold"><i class="fa-solid fa-pen-to-square"></i> Modificar Membresia</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Membresia.Id" />

                        <div class="mb-3">
                            <label asp-for="Membresia.NombrePlan" class="form-label" style="color: #D4AF37; font-weight: bold;">Nombre Plan de la Membresia</label>
                            <input asp-for="Membresia.NombrePlan" type="text" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Membresia.NombrePlan" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Membresia.CostoMensual" class="form-label" style="color: #D4AF37; font-weight: bold;">Costo Mensual de la Membresia</label>
                            <input asp-for="Membresia.CostoMensual" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Membresia.CostoMensual" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Membresia.DescuentoPorcentaje" class="form-label" style="color: #D4AF37; font-weight: bold;">DescuentoPorcentaje de la Membresia</label>
                            <input asp-for="Membresia.DescuentoPorcentaje" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Membresia.DescuentoPorcentaje" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Membresia.DiaVigencia" class="form-label" style="color: #D4AF37; font-weight: bold;">Dias de Vigencia</label>
                            <input asp-for="Membresia.DiaVigencia" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Membresia.DiaVigencia" class="text-danger"></span>
                        </div>

                  

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn fw-bold" style="background-color: #D4AF37; color: #121212;">
                                <i class="fa-solid fa-arrows-rotate"></i> Actualizar Membresia
                            </button>
                            <a asp-page="Index" class="btn btn-outline-light">⬅️ Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}