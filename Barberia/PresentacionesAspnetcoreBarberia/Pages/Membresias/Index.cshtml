@page
@model PresentacionesAspnetcoreBarberia.Pages.Membresias.IndexModel
@{
    ViewData["Title"] = "Lista de Membresias";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6" style="color: #D4AF37; font-weight: bold;">📅 Gestión de Membresias</h1>

        <a asp-page="Create" class="btn" style="background-color: #D4AF37; color: #121212; font-weight: bold;">
            ➕ Agregar Membresia
        </a>
    </div>

    <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
        <div class="card-body">
            <table class="table table-dark table-hover">
                <thead>
                    <tr style="border-bottom: 2px solid #D4AF37;">
                        <th style="width: 10%; color: #D4AF37;">ID</th>
                        <th style="color: #D4AF37;">Nombre Plan de la Membresia</th>
                        <th style="color: #D4AF37;">Costo Mensual de la Membresia</th>
                        <th style="color: #D4AF37;">Descuento Porcentaje</th>
                        <th style="color: #D4AF37;">Dias de Vigencia</th>

                        <th class="text-center" style="width: 20%; color: #D4AF37;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ListaMembresias.Any())
                    {
                        foreach (var Membresia in Model.ListaMembresias)
                        {
                            <tr>
                                <td>@Membresia.Id</td>
                                <td>@Membresia.NombrePlan</td>
                                <td>@Membresia.CostoMensual</td>
                                <td>@Membresia.DescuentoPorcentaje</td>
                                <td>@Membresia.DiaVigencia</td>
                               
                                
                                <td class="text-center">
                                    <a href="/Membresias/Edit/@Membresia.Id" class="btn btn-outline-warning btn-sm">
                                        Editar
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@Membresia.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Estás seguro de que deseas eliminar la Membresia del @Membresia.NombrePlan? Esta acción no se puede deshacer.');">
                                            Borrar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4" style="color: #FFFFFF;">
                                No se encontraron Membresias registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>