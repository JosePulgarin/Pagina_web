@page "{id:int}"
@model PresentacionesAspnetcoreBarberia.Pages.Productos.EditModel
@{
    ViewData["Title"] = "Editar Producto";
}

<div class="container mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
                <div class="card-header" style="background-color: #D4AF37; color: #121212;">
                    <h3 class="mb-0 fw-bold"><i class="fa-solid fa-pen-to-square"></i> Modificar Producto</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Producto.Id" />

                        <div class="mb-3">
                            <label asp-for="Producto.MarcaProducto" class="form-label" style="color: #D4AF37; font-weight: bold;">MarcaProducto de la Producto</label>
                            <input asp-for="Producto.MarcaProducto" type="text" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Producto.MarcaProducto" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Producto.NombreArticulo" class="form-label" style="color: #D4AF37; font-weight: bold;">NombreArticulo de la Producto</label>
                            <input asp-for="Producto.NombreArticulo" type="text" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Producto.NombreArticulo" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Producto.Precio" class="form-label" style="color: #D4AF37; font-weight: bold;">Precio de la Producto</label>
                            <input asp-for="Producto.Precio" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Producto.Precio" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Producto.StockActual" class="form-label" style="color: #D4AF37; font-weight: bold;">StockActual de la Producto</label>
                            <input asp-for="Producto.StockActual" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Producto.StockActual" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Producto.IdInventario" class="form-label" style="color: #D4AF37; font-weight: bold;">Id Inventario</label>
                            <input asp-for="Producto.IdInventario" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Producto.IdInventario" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Producto.IdProveedor" class="form-label" style="color: #D4AF37; font-weight: bold;">Id Proveedor</label>
                            <input asp-for="Producto.IdProveedor" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Producto.IdProveedor" class="text-danger"></span>
                        </div>

                        

                        <div class="mb-3">
                            <label asp-for="Producto.IdCategoria" class="form-label" style="color: #D4AF37; font-weight: bold;">Id Categoria</label>
                            <input asp-for="Producto.IdCategoria" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Producto.IdCategoria" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn fw-bold" style="background-color: #D4AF37; color: #121212;">
                                <i class="fa-solid fa-arrows-rotate"></i> Actualizar Producto
                            </button>
                            <a asp-page="Index" class="btn btn-outline-light">⬅️ Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}