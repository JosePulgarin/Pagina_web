@page
@model PresentacionesAspnetcoreBarberia.Pages.GastosOperativos.IndexModel
@{
    ViewData["Title"] = "Lista de GastosOperativos";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6" style="color: #D4AF37; font-weight: bold;">📅 Gestión de GastosOperativos</h1>

        <a asp-page="Create" class="btn" style="background-color: #D4AF37; color: #121212; font-weight: bold;">
            ➕ Agregar GastoOperativo
        </a>
    </div>

    <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
        <div class="card-body">
            <table class="table table-dark table-hover">
                <thead>
                    <tr style="border-bottom: 2px solid #D4AF37;">
                        <th style="width: 10%; color: #D4AF37;">ID</th>
                        <th style="color: #D4AF37;">Categoria del GastoOperativo</th>
                        <th style="color: #D4AF37;">Monto</th>
                        <th style="color: #D4AF37;">FechaPago</th>
                        <th style="color: #D4AF37;">NumeroComprobante</th>
                        <th style="color: #D4AF37;">Id de Sede</th>
                        <th class="text-center" style="width: 20%; color: #D4AF37;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ListaGastosOperativos.Any())
                    {
                        foreach (var GastoOperativo in Model.ListaGastosOperativos)
                        {
                            <tr>
                                <td>@GastoOperativo.Id</td>
                                <td>@GastoOperativo.Categoria</td>
                                <td>@GastoOperativo.Monto</td>
                                <td>@GastoOperativo.FechaPago</td>
                                <td>@GastoOperativo.NumeroComprobante</td>
                                <td>@GastoOperativo.IdSede</td>
                                <td class="text-center">
                                    <a href="/GastosOperativos/Edit/@GastoOperativo.Id" class="btn btn-outline-warning btn-sm">
                                        Editar
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@GastoOperativo.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Estás seguro de que deseas eliminar la GastoOperativo del @GastoOperativo.FechaPago? Esta acción no se puede deshacer.');">
                                            Borrar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4" style="color: #FFFFFF;">
                                No se encontraron GastosOperativos registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>