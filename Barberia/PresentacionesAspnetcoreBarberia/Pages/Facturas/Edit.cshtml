@page "{id:int}"
@model PresentacionesAspnetcoreBarberia.Pages.Facturas.EditModel
@{
    ViewData["Title"] = "Editar Factura";
}

<div class="container mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
                <div class="card-header" style="background-color: #D4AF37; color: #121212;">
                    <h3 class="mb-0 fw-bold"><i class="fa-solid fa-pen-to-square"></i> Modificar Factura</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Factura.Id" />

                        <div class="mb-3">
                            <label asp-for="Factura.NumeroFactura" class="form-label" style="color: #D4AF37; font-weight: bold;">Numero Factura</label>
                            <input asp-for="Factura.NumeroFactura" type="text" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Factura.NumeroFactura" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Factura.MontoSubTotal" class="form-label" style="color: #D4AF37; font-weight: bold;">MontoSubTotal Factura</label>
                            <input asp-for="Factura.MontoSubTotal" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Factura.MontoSubTotal" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Factura.IVA" class="form-label" style="color: #D4AF37; font-weight: bold;">IVA</label>
                            <input asp-for="Factura.IVA" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Factura.IVA" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Factura.Total" class="form-label" style="color: #D4AF37; font-weight: bold;">Total de la Factura</label>
                            <input asp-for="Factura.Total" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Factura.Total" class="text-danger"></span>
                        </div>

                       

                        <div class="mb-3">
                            <label asp-for="Factura.IdReserva" class="form-label" style="color: #D4AF37; font-weight: bold;">ID de reserva</label>
                            <input asp-for="Factura.IdReserva" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Factura.IdReserva" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Factura.IdMetodo" class="form-label" style="color: #D4AF37; font-weight: bold;">Metodo pago</label>
                            <input asp-for="Factura.IdMetodo" type="number" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Factura.IdMetodo" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn fw-bold" style="background-color: #D4AF37; color: #121212;">
                                <i class="fa-solid fa-arrows-rotate"></i> Actualizar Factura
                            </button>
                            <a asp-page="Index" class="btn btn-outline-light">⬅️ Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}