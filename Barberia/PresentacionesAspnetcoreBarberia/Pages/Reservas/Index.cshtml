@page
@model PresentacionesAspnetcoreBarberia.Pages.Reservas.IndexModel
@{
    ViewData["Title"] = "Lista de Reservas";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6" style="color: #D4AF37; font-weight: bold;">📅 Gestión de Reservas</h1>

        <a asp-page="Create" class="btn" style="background-color: #D4AF37; color: #121212; font-weight: bold;">
            ➕ Agregar Reserva
        </a>
    </div>

    <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
        <div class="card-body">
            <table class="table table-dark table-hover">
                <thead>
                    <tr style="border-bottom: 2px solid #D4AF37;">
                        <th style="width: 10%; color: #D4AF37;">ID</th>
                        <th style="color: #D4AF37;">Recordatorio de la Reserva</th>
                        <th style="color: #D4AF37;">Fecha de la Reserva</th>
                        <th style="color: #D4AF37;">Estado</th>
                        <th style="color: #D4AF37;">Notas</th>
                        <th style="color: #D4AF37;">Id Agenda</th>
                        <th style="color: #D4AF37;">Id Cliente</th>
                        <th class="text-center" style="width: 20%; color: #D4AF37;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ListaReservas.Any())
                    {
                        foreach (var Reserva in Model.ListaReservas)
                        {
                            <tr>
                                <td>@Reserva.Id</td>
                                <td>@Reserva.Recordatorio</td>
                                <td>@Reserva.Fecha</td>
                                <td>@Reserva.Estado</td>
                                <td>@Reserva.Notas</td>
                                <td>@Reserva.IdAgenda</td>
                                <td>@Reserva.IdCliente</td>
                           
                                <td class="text-center">
                                    <a href="/Reservas/Edit/@Reserva.Id" class="btn btn-outline-warning btn-sm">
                                        Editar
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@Reserva.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Estás seguro de que deseas eliminar la Reserva del @Reserva.Fecha? Esta acción no se puede deshacer.');">
                                            Borrar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4" style="color: #FFFFFF;">
                                No se encontraron Reservas registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>