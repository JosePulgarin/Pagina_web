@page
@model PresentacionesAspnetcoreBarberia.Pages.HorariosLaborales.IndexModel
@{
    ViewData["Title"] = "Lista de HorariosLaborales";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6" style="color: #D4AF37; font-weight: bold;">📅 Gestión de HorariosLaborales</h1>

        <a asp-page="Create" class="btn" style="background-color: #D4AF37; color: #121212; font-weight: bold;">
            ➕ Agregar HorarioLaboral
        </a>
    </div>

    <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
        <div class="card-body">
            <table class="table table-dark table-hover">
                <thead>
                    <tr style="border-bottom: 2px solid #D4AF37;">
                        <th style="width: 10%; color: #D4AF37;">ID</th>
                        <th style="color: #D4AF37;">Dia Horario Laboral</th>
                        <th style="color: #D4AF37;">Hora Apertura</th>
                        <th style="color: #D4AF37;">Hora Cierre</th>
                        <th style="color: #D4AF37;">¿Dia Festivo?</th>
                        <th style="color: #D4AF37;">ID sede</th>
                        <th class="text-center" style="width: 20%; color: #D4AF37;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ListaHorariosLaborales.Any())
                    {
                        foreach (var HorarioLaboral in Model.ListaHorariosLaborales)
                        {
                            <tr>
                                <td>@HorarioLaboral.Id</td>
                                <td>@HorarioLaboral.Dia</td>
                                <td>@HorarioLaboral.HoraApertura</td>
                                <td>@HorarioLaboral.HoraCierre</td>
                                <td>@HorarioLaboral.DiaFestivo</td>
                                <td>@HorarioLaboral.IdSede</td>
                                <td class="text-center">
                                    <a href="/HorariosLaborales/Edit/@HorarioLaboral.Id" class="btn btn-outline-warning btn-sm">
                                        Editar
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@HorarioLaboral.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Estás seguro de que deseas eliminar la HorarioLaboral del @HorarioLaboral.Dia? Esta acción no se puede deshacer.');">
                                            Borrar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4" style="color: #FFFFFF;">
                                No se encontraron HorariosLaborales registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>