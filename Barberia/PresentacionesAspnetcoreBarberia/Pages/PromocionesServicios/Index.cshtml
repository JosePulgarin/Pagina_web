@page
@model PresentacionesAspnetcoreBarberia.Pages.PromocionesServicios.IndexModel
@{
    ViewData["Title"] = "Lista de PromocionesServicios";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6" style="color: #D4AF37; font-weight: bold;">📅 Gestión de PromocionesServicios</h1>

        <a asp-page="Create" class="btn" style="background-color: #D4AF37; color: #121212; font-weight: bold;">
            ➕ Agregar PromocionServicio
        </a>
    </div>

    <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
        <div class="card-body">
            <table class="table table-dark table-hover">
                <thead>
                    <tr style="border-bottom: 2px solid #D4AF37;">
                        <th style="width: 10%; color: #D4AF37;">ID</th>
                        <th style="color: #D4AF37;">MontoDescuento PromocionServicio</th>
                        <th style="color: #D4AF37;">Descuento Finde de la PromocionServicio</th>
                        <th style="color: #D4AF37;">Id Servicio</th>
                        <th style="color: #D4AF37;"> Id Promocion Especial</th>
                        <th class="text-center" style="width: 20%; color: #D4AF37;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ListaPromocionesServicios.Any())
                    {
                        foreach (var PromocionServicio in Model.ListaPromocionesServicios)
                        {
                            <tr>
                                <td>@PromocionServicio.Id</td>
                                <td>@PromocionServicio.MontoDescuento</td>
                                <td>@PromocionServicio.DescuentoFinde</td>
                                <td>@PromocionServicio.IdServicio</td>
                                <td>@PromocionServicio.IdPromocionEspecial</td>
                               
                             
                                <td class="text-center">
                                    <a href="/PromocionesServicios/Edit/@PromocionServicio.Id" class="btn btn-outline-warning btn-sm">
                                        Editar
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@PromocionServicio.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Estás seguro de que deseas eliminar la PromocionServicio del @PromocionServicio.IdServicio? Esta acción no se puede deshacer.');">
                                            Borrar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4" style="color: #FFFFFF;">
                                No se encontraron PromocionesServicios registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>