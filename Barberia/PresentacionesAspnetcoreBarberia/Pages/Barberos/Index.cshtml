@page
@model PresentacionesAspnetcoreBarberia.Pages.Barberos.IndexModel
@{
    ViewData["Title"] = "Lista de Barberos";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6" style="color: #D4AF37; font-weight: bold;">📅 Gestión de Barberos</h1>

        <a asp-page="Create" class="btn" style="background-color: #D4AF37; color: #121212; font-weight: bold;">
            ➕ Agregar Barbero
        </a>
    </div>

    <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
        <div class="card-body">
            <table class="table table-dark table-hover">
                <thead>
                    <tr style="border-bottom: 2px solid #D4AF37;">
                        <th style="width: 10%; color: #D4AF37;">ID</th>
                        <th style="color: #D4AF37;">Nombre de Barbero</th>
                        <th style="color: #D4AF37;">Correo del Barbero</th>
                        <th style="color: #D4AF37;">Fecha de nacimiento</th>
                        <th style="color: #D4AF37;">Especialidad</th>
                        <th style="color: #D4AF37;">Biografia</th>
                        <th style="color: #D4AF37;">Id del usuario</th>
                        <th style="color: #D4AF37;">Id del sede</th>

                        <th class="text-center" style="width: 20%; color: #D4AF37;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ListaBarberos.Any())
                    {
                        foreach (var Barbero in Model.ListaBarberos)
                        {
                            <tr>
                                <td>@Barbero.Id</td>
                                <td>@Barbero.Nombre</td>
                                <td>@Barbero.Correo</td>
                                <td>@Barbero.FechaNacimiento</td>
                                <td>@Barbero.Especialidad</td>
                                <td>@Barbero.Biografia</td>
                                <td>@Barbero.IdUsuario</td>
              
                                <td>@Barbero.IdSede</td>
                                <td class="text-center">
                                    <a href="/Barberos/Edit/@Barbero.Id" class="btn btn-outline-warning btn-sm">
                                        Editar
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@Barbero.Id" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Estás seguro de que deseas eliminar la Barbero del @Barbero.FechaNacimiento? Esta acción no se puede deshacer.');">
                                            Borrar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4" style="color: #FFFFFF;">
                                No se encontraron Barberos registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>