@page
@model PresentacionesAspnetcoreBarberia.Pages.Proveedores.CreateModel
@{
    ViewData["Title"] = "Nueva Proveedor";
}

<div class="container mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm" style="background-color: #1E1E1E; border: 1px solid #D4AF37;">
                <div class="card-header" style="background-color: #D4AF37; color: #121212;">
                    <h3 class="mb-0 fw-bold">📅 Registrar Nueva Proveedor</h3>
                </div>
                <div class="card-body">
                    <form method="post">

                        <div class="mb-3">
                            <label asp-for="Proveedor.Nombre" class="form-label" style="color: #D4AF37; font-weight: bold;">Nombre de la Proveedor</label>
                            <input asp-for="Proveedor.Nombre" type="text" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Proveedor.Nombre" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Proveedor.NombreEmpresa" class="form-label" style="color: #D4AF37; font-weight: bold;">NombreEmpresa de la Proveedor</label>
                            <input asp-for="Proveedor.NombreEmpresa" type="text" class="form-control text-white" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Proveedor.NombreEmpresa" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Proveedor.Correo" class="form-label" style="color: #D4AF37; font-weight: bold;">Correo</label>
                            <input asp-for="Proveedor.Correo" type="email" class="form-control text-white" placeholder="Ej: 1" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Proveedor.Correo" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Proveedor.Telefono" class="form-label" style="color: #D4AF37; font-weight: bold;">Telefono</label>
                            <input asp-for="Proveedor.Telefono" type="text" class="form-control text-white" placeholder="Ej: 1" style="background-color: #121212; border: 1px solid #6c757d;" required />
                            <span asp-validation-for="Proveedor.Telefono" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn fw-bold" style="background-color: #D4AF37; color: #121212;">
                                💾 Guardar Proveedor
                            </button>
                            <a asp-page="Index" class="btn btn-outline-light">⬅️ Cancelar y Volver</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}